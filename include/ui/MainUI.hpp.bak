/**
 * S.O.S - Save Our Switch
 * Main UI - SX OS inspired clean interface
 */

#pragma once

#include <SDL2/SDL.h>
#include <SDL2/SDL_image.h>
#include <SDL2/SDL_ttf.h>
#include <vector>
#include <string>
#include <memory>

#include "core/SaveManager.hpp"
#include "network/GoogleDrive.hpp"
#include "utils/Logger.hpp"

namespace ui {

// Color scheme (SX OS inspired)
namespace Color {
    constexpr SDL_Color Background = {30, 30, 40, 255};
    constexpr SDL_Color Header = {45, 45, 60, 255};
    constexpr SDL_Color Card = {50, 50, 65, 255};
    constexpr SDL_Color CardHover = {60, 60, 80, 255};
    constexpr SDL_Color Accent = {0, 200, 150, 255};      // SOS Green
    constexpr SDL_Color Warning = {255, 180, 0, 255};
    constexpr SDL_Color Error = {255, 80, 80, 255};
    constexpr SDL_Color Text = {255, 255, 255, 255};
    constexpr SDL_Color TextDim = {180, 180, 180, 255};
    constexpr SDL_Color Synced = {80, 200, 120, 255};
    constexpr SDL_Color NotSynced = {200, 100, 100, 255};
}

// UI State
enum class State {
    Main,           // Game list
    GameDetail,     // Selected game options
    VersionHistory, // Version list for selected game
    ConflictResolve,// Upload vs Download choice
    Auth,           // Google Drive authentication
    SyncAll,        // Batch sync progress
    Settings        // Settings menu
};

// Button
struct Button {
    SDL_Rect rect;
    std::string text;
    bool hover;
    bool enabled;
    
    Button(int x, int y, int w, int h, const std::string& t)
        : text(t), hover(false), enabled(true) {
        rect = {x, y, w, h};
    }
    
    bool contains(int px, int py) const {
        return px >= rect.x && px < rect.x + rect.w &&
               py >= rect.y && py < rect.y + rect.h;
    }
};

// Game card for grid view
struct GameCard {
    core::TitleInfo* title;
    SDL_Rect rect;
    SDL_Texture* icon;
    bool selected;
    network::SyncStatus syncStatus;
};

// Version list item
struct VersionItem {
    core::BackupVersion version;
    SDL_Rect rect;
    bool selected;
    bool isLocal;     // true = local backup, false = cloud backup
    bool isCurrent;   // true if this is the current active save (only for display)
};

class MainUI {
public:
    MainUI(SDL_Renderer* renderer, network::GoogleDrive& drive, core::SaveManager& saveMgr);
    ~MainUI();
    
    bool initialize();
    void handleEvent(const SDL_Event& event);
    void update();
    void render();
    
    void showAuthScreen();
    bool shouldExit() const { return m_shouldExit; }
    
private:
    SDL_Renderer* m_renderer;
    network::GoogleDrive& m_drive;
    core::SaveManager& m_saveManager;
    
    // Fonts
    TTF_Font* m_fontLarge;
    TTF_Font* m_fontMedium;
    TTF_Font* m_fontSmall;
    
    // State
    State m_state;
    bool m_shouldExit;
    int m_selectedIndex;
    int m_scrollOffset;
    
    // Game cards
    std::vector<GameCard> m_gameCards;
    
    // Buttons
    std::vector<Button> m_buttons;
    
    // Auth state
    network::AuthState m_authState;
    std::string m_authMessage;
    
    // Current selected game
    core::TitleInfo* m_selectedTitle;
    
    // Sync progress
    int m_syncProgress;
    int m_syncTotal;
    std::string m_syncStatus;
    
    // Version history
    std::vector<VersionItem> m_versionItems;
    int m_selectedVersionIndex;
    core::BackupVersion* m_selectedVersion;
    
    // Conflict resolution
    network::SyncStatus m_conflictStatus;
    std::string m_localTime;
    std::string m_cloudTime;
    // Touch/Mouse state
    int m_touchX, m_touchY;
    bool m_touchPressed;
    
    // UI dimensions
    static constexpr int CARD_WIDTH = 200;
    static constexpr int CARD_HEIGHT = 280;
    static constexpr int CARD_MARGIN = 20;
    static constexpr int HEADER_HEIGHT = 80;
    static constexpr int FOOTER_HEIGHT = 60;
    
    // Rendering methods
    void renderHeader();
    void renderFooter();
    void renderGameList();
    void renderGameDetail();
    void renderVersionHistory();
    void renderConflictResolve();
    void renderAuthScreen();
    void renderSyncProgress();
    void renderSettings();
    // Helper methods
    void renderText(const std::string& text, int x, int y, TTF_Font* font, 
                    SDL_Color color = Color::Text);
    void renderTextCentered(const std::string& text, int x, int y, int w, 
                           TTF_Font* font, SDL_Color color = Color::Text);
    void renderButton(const Button& btn);
    void renderCard(const GameCard& card);
    void renderSyncBadge(int x, int y, network::SyncStatus status);
    
    SDL_Texture* renderTextToTexture(const std::string& text, TTF_Font* font, 
                                     SDL_Color color, int* w, int* h);
    SDL_Texture* loadIcon(const std::string& path);
    
    void updateGameCards();
    void handleTouch(int x, int y, bool pressed);
    void handleButtonPress(const Button& btn);
    
    // Actions
    void syncSelectedToCloud();
    void downloadFromCloud();
    void backupSelected();
    void restoreSelected();
    void syncAllGames();
    
    // Version history actions
    void showVersionHistory();
    void loadVersionHistory();
    void restoreLocalVersion(core::BackupVersion* version);
    void downloadCloudVersion(network::CloudFile* file);
    
    // Quick actions
    void quickBackup();   // Backup current to local
    void quickUpload();   // Upload current to cloud
    void quickDownload(); // Download cloud to current
    void quickRestore();  // Restore local to current
    
    // Conflict resolution
    void showConflictResolve();
    void resolveUpload();   // Upload current to cloud
    void resolveDownload(); // Download cloud to current

} // namespace ui
