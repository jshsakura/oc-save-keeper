# Dropbox App Credentials
# -----------------------
# Get your App Key from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_dropbox_app_key_here

# Security (CRITICAL)
# ------------------
# A long random string used to secure polling tokens.
# Generate one using: openssl rand -hex 64
POLL_TOKEN_SECRET=generate_a_long_random_string_here

# Service URL
# -----------
# The public URL where this bridge is hosted. 
# Must match the Redirect URI in Dropbox App Console: ${DROPBOX_BRIDGE_BASE}/oauth/dropbox/callback
DROPBOX_BRIDGE_BASE=https://example.yourdomain.com

# Session Settings (Optional)
# ---------------------------
# How long (in seconds) a login session/QR code remains valid. Default: 900 (15 min)
# STATE_TTL_SECONDS=900
# SESSION_TTL_SECONDS=900

# Infrastructure (Automatically handled by docker-compose)
# -------------------------------------------------------
# REDIS_URL=redis://redis:6379/0

# Redis Authentication (Optional)
# -------------------------------
# Password for Redis server. Leave empty for no authentication.
# Generate one using: openssl rand -hex 32
REDIS_PASSWORD=
