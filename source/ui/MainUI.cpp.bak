/**
 * S.O.S - Save Our Switch
 * Main UI implementation - SX OS style
 */

#include "ui/MainUI.hpp"
#include <algorithm>

namespace ui {

MainUI::MainUI(SDL_Renderer* renderer, network::GoogleDrive& drive, core::SaveManager& saveMgr)
    : m_renderer(renderer)
    , m_drive(drive)
    , m_saveManager(saveMgr)
    , m_fontLarge(nullptr)
    , m_fontMedium(nullptr)
    , m_fontSmall(nullptr)
    , m_state(State::Main)
    , m_shouldExit(false)
    , m_selectedIndex(0)
    , m_scrollOffset(0)
    , m_selectedTitle(nullptr)
    , m_syncProgress(0)
    , m_syncTotal(0)
    , m_selectedVersionIndex(0)
    , m_selectedVersion(nullptr)
    , m_touchX(0)
    , m_touchY(0)
    , m_touchPressed(false) {
}

MainUI::~MainUI() {
    if (m_fontLarge) TTF_CloseFont(m_fontLarge);
    if (m_fontMedium) TTF_CloseFont(m_fontMedium);
    if (m_fontSmall) TTF_CloseFont(m_fontSmall);
    TTF_Quit();
}

bool MainUI::initialize() {
    // Initialize SDL_ttf
    if (TTF_Init() < 0) {
        LOG_ERROR("TTF_Init failed: %s", TTF_GetError());
        return false;
    }
    
    // Load fonts (using system font)
    // On Switch, we'd load from romfs or use shared font
    // For now, use a placeholder approach
    m_fontLarge = TTF_OpenFont("/switch/sos/fonts/NotoSansCJK-Bold.ttc", 36);
    m_fontMedium = TTF_OpenFont("/switch/sos/fonts/NotoSansCJK-Regular.ttc", 24);
    m_fontSmall = TTF_OpenFont("/switch/sos/fonts/NotoSansCJK-Regular.ttc", 18);
    
    // If fonts don't load, we'll use basic rendering
    if (!m_fontLarge || !m_fontMedium || !m_fontSmall) {
        LOG_WARNING("Custom fonts not found, using fallback");
        // Try system fonts
        m_fontLarge = TTF_OpenFont("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf", 36);
        m_fontMedium = TTF_OpenFont("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 24);
        m_fontSmall = TTF_OpenFont("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 18);
    }
    
    // Initial scan
    m_saveManager.scanTitles();
    updateGameCards();
    
    return true;
}

void MainUI::updateGameCards() {
    m_gameCards.clear();
    
    auto titles = m_saveManager.getTitlesWithSaves();
    
    int cols = (1280 - CARD_MARGIN) / (CARD_WIDTH + CARD_MARGIN);
    int row = 0, col = 0;
    
    for (auto* title : titles) {
        GameCard card;
        card.title = title;
        card.selected = false;
        card.syncStatus = m_drive.getSyncStatus(
            m_saveManager.getBackupPath(title), 
            "" // Cloud file ID would be cached
        );
        
        int x = CARD_MARGIN + col * (CARD_WIDTH + CARD_MARGIN);
        int y = HEADER_HEIGHT + CARD_MARGIN + row * (CARD_HEIGHT + CARD_MARGIN);
        card.rect = {x, y, CARD_WIDTH, CARD_HEIGHT};
        
        // Load icon
        card.icon = loadIcon(title->iconPath);
        
        m_gameCards.push_back(card);
        
        col++;
        if (col >= cols) {
            col = 0;
            row++;
        }
    }
}

void MainUI::handleEvent(const SDL_Event& event) {
    switch (event.type) {
        case SDL_QUIT:
            m_shouldExit = true;
            break;
            
        case SDL_JOYBUTTONDOWN: {
            int button = event.jbutton.button;
            switch (button) {
                case 0: // A - Select/Confirm
                    if (m_state == State::Main && m_selectedIndex < (int)m_gameCards.size()) {
                        m_selectedTitle = m_gameCards[m_selectedIndex].title;
                        m_state = State::GameDetail;
                    }
                    break;
                case 1: // B - Back
                    if (m_state == State::GameDetail) {
                        m_state = State::Main;
                        m_selectedTitle = nullptr;
                    }
                    break;
                case 10: // Plus - Exit
                    m_shouldExit = true;
                    break;
            }
            break;
        }
            
        case SDL_JOYHATMOTION: {
            int hat = event.jhat.value;
            if (hat & SDL_HAT_UP) {
                m_selectedIndex = std::max(0, m_selectedIndex - 4);
            } else if (hat & SDL_HAT_DOWN) {
                m_selectedIndex = std::min((int)m_gameCards.size() - 1, m_selectedIndex + 4);
            } else if (hat & SDL_HAT_LEFT) {
                m_selectedIndex = std::max(0, m_selectedIndex - 1);
            } else if (hat & SDL_HAT_RIGHT) {
                m_selectedIndex = std::min((int)m_gameCards.size() - 1, m_selectedIndex + 1);
            }
            break;
        }
            
        case SDL_FINGERDOWN:
        case SDL_MOUSEBUTTONDOWN:
            m_touchPressed = true;
            if (event.type == SDL_FINGERDOWN) {
                m_touchX = event.tfinger.x * 1280;
                m_touchY = event.tfinger.y * 720;
            } else {
                m_touchX = event.button.x;
                m_touchY = event.button.y;
            }
            handleTouch(m_touchX, m_touchY, true);
            break;
            
        case SDL_FINGERUP:
        case SDL_MOUSEBUTTONUP:
            m_touchPressed = false;
            break;
    }
}

void MainUI::handleTouch(int x, int y, bool pressed) {
    if (!pressed) return;
    
    if (m_state == State::Main) {
        // Check game cards
        for (size_t i = 0; i < m_gameCards.size(); i++) {
            if (m_gameCards[i].rect.containsPoint(x, y)) {
                m_selectedIndex = i;
                m_selectedTitle = m_gameCards[i].title;
                m_state = State::GameDetail;
                break;
            }
        }
    } else if (m_state == State::GameDetail) {
        // Check buttons
        for (const auto& btn : m_buttons) {
            if (btn.enabled && btn.contains(x, y)) {
                handleButtonPress(btn);
                break;
            }
        }
    } else if (m_state == State::Auth) {
        // Auth screen has cancel button
        for (const auto& btn : m_buttons) {
            if (btn.enabled && btn.contains(x, y)) {
                handleButtonPress(btn);
                break;
            }
        }
    }
}

void MainUI::handleButtonPress(const Button& btn) {
    if (btn.text == "☁️ 클라우드 업로드") {
        syncSelectedToCloud();
    } else if (btn.text == "📥 클라우드 다운로드") {
        downloadFromCloud();
    } else if (btn.text == "💾 로컬 백업") {
        backupSelected();
    } else if (btn.text == "📂 로컬 복원") {
        restoreSelected();
    } else if (btn.text == "📜 버전 히스토리") {
        showVersionHistory();
    } else if (btn.text == "⬅️ 뒤로") {
        if (m_state == State::VersionHistory || m_state == State::ConflictResolve) {
            m_state = State::GameDetail;
        } else {
            m_state = State::Main;
            m_selectedTitle = nullptr;
        }
    } else if (btn.text == "취소") {
        m_drive.cancelDeviceFlow();
        m_state = State::Main;
    } else if (btn.text == "🔄 전체 동기화") {
        syncAllGames();
    } else if (btn.text == "⬆️ 내 세이브 업로드") {
        resolveUpload();
    } else if (btn.text == "⬇️ 클라우드에서 다운로드") {
        resolveDownload();
    } else if (btn.text.find("복원") != std::string::npos) {
        // Version restore button
        if (m_selectedVersionIndex < (int)m_versionItems.size()) {
            restoreVersion(&m_versionItems[m_selectedVersionIndex].version);
        }
}

void MainUI::update() {
    // Poll auth if in auth state
    if (m_state == State::Auth && m_authState.isPolling) {
        if (m_drive.pollDeviceFlow(m_authState)) {
            m_authState.isPolling = false;
            m_state = State::Main;
            LOG_INFO("Authentication successful!");
        }
    }
}

void MainUI::render() {
    // Clear screen
    SDL_SetRenderDrawColor(m_renderer, Color::Background.r, Color::Background.g,
                          Color::Background.b, Color::Background.a);
    SDL_RenderClear(m_renderer);
    
    switch (m_state) {
        case State::Main:
            renderHeader();
            renderGameList();
            renderFooter();
            break;
            
        case State::GameDetail:
            renderHeader();
            renderGameDetail();
            break;
            
        case State::VersionHistory:
            renderHeader();
            renderVersionHistory();
            break;
            
        case State::ConflictResolve:
            renderHeader();
            renderConflictResolve();
            break;
            
        case State::Auth:
            renderAuthScreen();
            break;
            
        case State::SyncAll:
            renderSyncProgress();
            break;
            
        case State::Settings:
            renderSettings();
            break;
}

void MainUI::renderHeader() {
    // Header background
    SDL_Rect headerRect = {0, 0, 1280, HEADER_HEIGHT};
    SDL_SetRenderDrawColor(m_renderer, Color::Header.r, Color::Header.g,
                          Color::Header.b, Color::Header.a);
    SDL_RenderFillRect(m_renderer, &headerRect);
    
    // Title
    renderText("S.O.S - Save Our Switch", 20, 25, m_fontLarge, Color::Accent);
    
    // Connection status
    bool connected = m_drive.isAuthenticated();
    std::string status = connected ? "☁️ 연결됨" : "☁️ 연결 안됨";
    SDL_Color statusColor = connected ? Color::Synced : Color::NotSynced;
    renderText(status, 1100, 30, m_fontMedium, statusColor);
}

void MainUI::renderFooter() {
    // Footer background
    SDL_Rect footerRect = {0, 720 - FOOTER_HEIGHT, 1280, FOOTER_HEIGHT};
    SDL_SetRenderDrawColor(m_renderer, Color::Header.r, Color::Header.g,
                          Color::Header.b, Color::Header.a);
    SDL_RenderFillRect(m_renderer, &footerRect);
    
    // Instructions
    renderText("A: 선택  |  B: 뒤로  |  X: 전체 동기화  |  +: 종료", 
              20, 720 - FOOTER_HEIGHT + 20, m_fontSmall, Color::TextDim);
    
    // Game count
    std::string count = std::to_string(m_gameCards.size()) + "개 게임";
    renderText(count, 1150, 720 - FOOTER_HEIGHT + 20, m_fontSmall, Color::TextDim);
}

void MainUI::renderGameList() {
    int cols = (1280 - CARD_MARGIN) / (CARD_WIDTH + CARD_MARGIN);
    
    for (size_t i = 0; i < m_gameCards.size(); i++) {
        GameCard& card = m_gameCards[i];
        
        // Highlight selected
        card.selected = ((int)i == m_selectedIndex);
        
        // Check if visible
        if (card.rect.y + card.rect.h < HEADER_HEIGHT ||
            card.rect.y > 720 - FOOTER_HEIGHT) {
            continue;
        }
        
        renderCard(card);
    }
}

void MainUI::renderCard(const GameCard& card) {
    // Card background
    SDL_Color bgColor = card.selected ? Color::CardHover : Color::Card;
    SDL_SetRenderDrawColor(m_renderer, bgColor.r, bgColor.g, bgColor.b, bgColor.a);
    SDL_RenderFillRect(m_renderer, &card.rect);
    
    // Selection border
    if (card.selected) {
        SDL_SetRenderDrawColor(m_renderer, Color::Accent.r, Color::Accent.g,
                              Color::Accent.b, Color::Accent.a);
        SDL_RenderDrawRect(m_renderer, &card.rect);
    }
    
    // Game icon (placeholder if not loaded)
    SDL_Rect iconRect = {card.rect.x + 10, card.rect.y + 10, 180, 180};
    if (card.icon) {
        SDL_RenderCopy(m_renderer, card.icon, nullptr, &iconRect);
    } else {
        // Placeholder
        SDL_SetRenderDrawColor(m_renderer, 70, 70, 90, 255);
        SDL_RenderFillRect(m_renderer, &iconRect);
        renderTextCentered("🎮", iconRect.x, iconRect.y + 70, 180, m_fontLarge, Color::Text);
    }
    
    // Game name (truncate if needed)
    std::string name = card.title->name;
    if (name.length() > 18) {
        name = name.substr(0, 15) + "...";
    }
    renderTextCentered(name, card.rect.x, card.rect.y + 200, CARD_WIDTH, 
                      m_fontMedium, Color::Text);
    
    // Sync status badge
    renderSyncBadge(card.rect.x + CARD_WIDTH - 40, card.rect.y + 10, card.syncStatus);
}

void MainUI::renderSyncBadge(int x, int y, network::SyncStatus status) {
    SDL_Color color;
    const char* icon;
    
    switch (status) {
        case network::SyncStatus::Synced:
            color = Color::Synced;
            icon = "✓";
            break;
        case network::SyncStatus::LocalNewer:
        case network::SyncStatus::CloudNewer:
            color = Color::Warning;
            icon = "⟳";
            break;
        case network::SyncStatus::Conflict:
            color = Color::Error;
            icon = "!";
            break;
        default:
            color = Color::NotSynced;
            icon = "○";
            break;
    }
    
    // Badge background
    SDL_Rect badgeRect = {x, y, 30, 30};
    SDL_SetRenderDrawColor(m_renderer, color.r, color.g, color.b, 200);
    SDL_RenderFillRect(m_renderer, &badgeRect);
    
    renderTextCentered(icon, x, y + 5, 30, m_fontSmall, Color::Text);
}

void MainUI::renderGameDetail() {
    if (!m_selectedTitle) return;
    
    // Background card
    SDL_Rect detailRect = {100, HEADER_HEIGHT + 50, 1080, 500};
    SDL_SetRenderDrawColor(m_renderer, Color::Card.r, Color::Card.g,
                          Color::Card.b, Color::Card.a);
    SDL_RenderFillRect(m_renderer, &detailRect);
    
    // Game info section
    int y = HEADER_HEIGHT + 80;
    
    // Title
    renderText(m_selectedTitle->name, 150, y, m_fontLarge, Color::Text);
    y += 50;
    
    // Publisher
    renderText(m_selectedTitle->publisher, 150, y, m_fontMedium, Color::TextDim);
    y += 40;
    
    // Title ID
    char idStr[32];
    snprintf(idStr, sizeof(idStr), "Title ID: %016lX", m_selectedTitle->titleId);
    renderText(idStr, 150, y, m_fontSmall, Color::TextDim);
    y += 30;
    
    // Save size
    char sizeStr[64];
    snprintf(sizeStr, sizeof(sizeStr), "세이브 크기: %.2f MB", 
            m_selectedTitle->saveSize / (1024.0 * 1024.0));
    renderText(sizeStr, 150, y, m_fontSmall, Color::TextDim);
    y += 60;
    
    // Sync status
    std::string syncText = m_drive.isAuthenticated() ? 
        "☁️ 클라우드: 연결됨" : "☁️ 클라우드: 연결 필요";
    renderText(syncText, 150, y, m_fontMedium, 
              m_drive.isAuthenticated() ? Color::Synced : Color::NotSynced);
    
    // Buttons - Row 1
    m_buttons.clear();
    int btnY = HEADER_HEIGHT + 320;
    int btnW = 250;
    int btnH = 50;
    
    m_buttons.emplace_back(150, btnY, btnW, btnH, "☁️ 클라우드 업로드");
    m_buttons.emplace_back(420, btnY, btnW, btnH, "📥 클라우드 다운로드");
    m_buttons.emplace_back(690, btnY, btnW, btnH, "📜 버전 히스토리");
    m_buttons.emplace_back(960, btnY, btnW, btnH, "⬅️ 뒤로");
    
    for (const auto& btn : m_buttons) {
        renderButton(btn);
    }
    
    // Quick info - recent backups
    auto versions = m_saveManager.getBackupVersions(m_selectedTitle);
    renderText("최근 백업:", 150, btnY + 70, m_fontMedium, Color::Text);
    
    if (!versions.empty()) {
        char verText[128];
        strftime(verText, sizeof(verText), "%Y-%m-%d %H:%M", localtime(&versions[0].timestamp));
        renderText(verText, 280, btnY + 70, m_fontMedium, Color::TextDim);
        
        char countStr[64];
        snprintf(countStr, sizeof(countStr), "(총 %zu개 버전)", versions.size());
        renderText(countStr, 500, btnY + 70, m_fontMedium, Color::Accent);
    } else {
        renderText("없음", 280, btnY + 70, m_fontMedium, Color::TextDim);
    }

void MainUI::renderButton(const Button& btn) {
    SDL_Color bgColor = btn.hover ? Color::CardHover : Color::Accent;
    if (!btn.enabled) bgColor = Color::Card;
    
    SDL_SetRenderDrawColor(m_renderer, bgColor.r, bgColor.g, bgColor.b, bgColor.a);
    SDL_RenderFillRect(m_renderer, &btn.rect);
    
    renderTextCentered(btn.text, btn.rect.x, btn.rect.y + 15, btn.rect.w, 
                      m_fontMedium, Color::Text);
}

void MainUI::renderAuthScreen() {
    // Dark overlay
    SDL_SetRenderDrawBlendMode(m_renderer, SDL_BLENDMODE_BLEND);
    SDL_SetRenderDrawColor(m_renderer, 0, 0, 0, 200);
    SDL_RenderFillRect(m_renderer, nullptr);
    
    // Auth card
    SDL_Rect authRect = {140, 100, 1000, 520};
    SDL_SetRenderDrawColor(m_renderer, Color::Card.r, Color::Card.g,
                          Color::Card.b, 255);
    SDL_RenderFillRect(m_renderer, &authRect);
    
    // Title
    renderTextCentered("☁️ Dropbox 연동 설정", 140, 120, 1000, m_fontLarge, Color::Accent);
    
    int y = 180;
    
    renderText("📱 폰으로 1회성 설정 (2분)", 180, y, m_fontMedium, Color::Warning);
    y += 50;
    
    // Step 1
    renderText("1. 폰 브라우저로 접속:", 180, y, m_fontMedium, Color::Text);
    y += 30;
    renderText("   dropbox.com/developers/apps", 180, y, m_fontMedium, Color::Accent);
    y += 45;
    
    // Step 2
    renderText("2. [Create App] 클릭", 180, y, m_fontMedium, Color::Text);
    y += 30;
    renderText("   - API: Dropbox API", 180, y, m_fontSmall, Color::TextDim);
    y += 25;
    renderText("   - Access: App folder", 180, y, m_fontSmall, Color::TextDim);
    y += 25;
    renderText("   - Name: SOS-Backup", 180, y, m_fontSmall, Color::TextDim);
    y += 45;
    
    // Step 3
    renderText("3. [Generated access token] → [Generate]", 180, y, m_fontMedium, Color::Text);
    y += 45;
    
    // Step 4
    renderText("4. 토큰 복사 후 아래에 입력:", 180, y, m_fontMedium, Color::Text);
    y += 35;
    
    // Token input box
    SDL_Rect tokenBox = {180, y, 920, 50};
    SDL_SetRenderDrawColor(m_renderer, 40, 40, 55, 255);
    SDL_RenderFillRect(m_renderer, &tokenBox);
    SDL_SetRenderDrawColor(m_renderer, Color::Accent.r, Color::Accent.g, Color::Accent.b, 255);
    SDL_RenderDrawRect(m_renderer, &tokenBox);
    
    std::string displayToken = m_authToken;
    if (displayToken.length() > 30) {
        displayToken = displayToken.substr(0, 12) + "..." + displayToken.substr(displayToken.length() - 12);
    }
    if (displayToken.empty()) {
        renderText("여기에 토큰 붙여넣기...", 200, y + 15, m_fontMedium, Color::TextDim);
    } else {
        renderText(displayToken, 200, y + 15, m_fontMedium, Color::Text);
    }
    y += 70;
    
    // Buttons
    m_buttons.clear();
    m_buttons.emplace_back(300, y, 200, 50, "✅ 연결");
    m_buttons.emplace_back(520, y, 200, 50, "❌ 취소");
    
    for (const auto& btn : m_buttons) {
        renderButton(btn);
    }
    
    // Footer
    renderTextCentered("💡 1회 설정으로 영구 사용 가능", 140, y + 70, 1000, m_fontSmall, Color::TextDim);
    renderTextCentered("키보드로 토큰 입력 | A: 연결 | B: 취소", 140, y + 95, 1000, m_fontSmall, Color::TextDim);
}

void MainUI::renderSyncProgress() {
    // Dark overlay
    SDL_SetRenderDrawBlendMode(m_renderer, SDL_BLENDMODE_BLEND);
    SDL_SetRenderDrawColor(m_renderer, 0, 0, 0, 200);
    SDL_RenderFillRect(m_renderer, nullptr);
    
    // Progress card
    SDL_Rect progressRect = {340, 260, 600, 200};
    SDL_SetRenderDrawColor(m_renderer, Color::Card.r, Color::Card.g,
                          Color::Card.b, 255);
    SDL_RenderFillRect(m_renderer, &progressRect);
    
    renderTextCentered("동기화 진행 중...", 340, 280, 600, m_fontLarge, Color::Accent);
    
    // Progress bar
    SDL_Rect barBg = {380, 340, 520, 30};
    SDL_SetRenderDrawColor(m_renderer, 50, 50, 60, 255);
    SDL_RenderFillRect(m_renderer, &barBg);
    
    if (m_syncTotal > 0) {
        int progress = (int)((float)m_syncProgress / m_syncTotal * 520);
        SDL_Rect barFill = {380, 340, progress, 30};
        SDL_SetRenderDrawColor(m_renderer, Color::Accent.r, Color::Accent.g,
                              Color::Accent.b, Color::Accent.a);
        SDL_RenderFillRect(m_renderer, &barFill);
    }
    
    // Status text
    renderTextCentered(m_syncStatus, 340, 390, 600, m_fontMedium, Color::Text);
    
    // Percentage
    char percent[16];
    snprintf(percent, sizeof(percent), "%d%%", 
            m_syncTotal > 0 ? (int)((float)m_syncProgress / m_syncTotal * 100) : 0);
    renderTextCentered(percent, 340, 420, 600, m_fontMedium, Color::TextDim);
}

void MainUI::renderSettings() {
    // TODO: Settings UI
}

void MainUI::showAuthScreen() {
    if (m_drive.startDeviceFlow(m_authState)) {
        m_state = State::Auth;
    }
}

void MainUI::syncSelectedToCloud() {
    if (!m_selectedTitle || !m_drive.isAuthenticated()) {
        return;
    }
    
    // First backup locally
    m_saveManager.createVersionedBackup(m_selectedTitle);
    
    // Get backup path
    std::string backupPath = m_saveManager.getBackupPath(m_selectedTitle);
    
    // Upload to Drive
    m_drive.uploadFile(backupPath, m_selectedTitle->name + ".zip", 
                      m_drive.getRootFolderId());
}

void MainUI::downloadFromCloud() {
    if (!m_selectedTitle || !m_drive.isAuthenticated()) {
        return;
    }
    
    // TODO: Download from Drive and restore
}

void MainUI::backupSelected() {
    if (!m_selectedTitle) return;
    m_saveManager.createVersionedBackup(m_selectedTitle);
}

void MainUI::restoreSelected() {
    showVersionHistory();
}

void MainUI::syncAllGames() {
    m_state = State::SyncAll;
    m_syncProgress = 0;
    m_syncTotal = m_gameCards.size();
    m_syncStatus = "동기화 시작...";
    
    for (auto& card : m_gameCards) {
        m_syncStatus = card.title->name + " 동기화 중...";
        syncSelectedToCloud();
        m_syncProgress++;
    }
    
    m_syncStatus = "완료!";
    m_state = State::Main;
}

// Helper to render text
void MainUI::renderText(const std::string& text, int x, int y, TTF_Font* font, SDL_Color color) {
    if (!font) {
        // Fallback: just draw rectangles for letters (very basic)
        return;
    }
    
    SDL_Surface* surface = TTF_RenderUTF8_Blended(font, text.c_str(), color);
    if (!surface) return;
    
    SDL_Texture* texture = SDL_CreateTextureFromSurface(m_renderer, surface);
    if (texture) {
        SDL_Rect dest = {x, y, surface->w, surface->h};
        SDL_RenderCopy(m_renderer, texture, nullptr, &dest);
        SDL_DestroyTexture(texture);
    }
    
    SDL_FreeSurface(surface);
}

void MainUI::renderTextCentered(const std::string& text, int x, int y, int w, 
                                TTF_Font* font, SDL_Color color) {
    if (!font) return;
    
    int textW, textH;
    TTF_SizeUTF8(font, text.c_str(), &textW, &textH);
    
    int centeredX = x + (w - textW) / 2;
    renderText(text, centeredX, y, font, color);
}

SDL_Texture* MainUI::loadIcon(const std::string& path) {
    if (path.empty()) return nullptr;
    
    SDL_Surface* surface = IMG_Load(path.c_str());
    if (!surface) return nullptr;
    
    SDL_Texture* texture = SDL_CreateTextureFromSurface(m_renderer, surface);
    SDL_FreeSurface(surface);
    
    return texture;
}

// ==================== Version History ====================

void MainUI::showVersionHistory() {
    if (!m_selectedTitle) return;
    
    loadVersionHistory();
    m_state = State::VersionHistory;
    m_selectedVersionIndex = 0;
}

void MainUI::loadVersionHistory() {
    m_versionItems.clear();
    
    if (!m_selectedTitle) return;
    
    // Load local versions
    auto localVersions = m_saveManager.getBackupVersions(m_selectedTitle);
    
    int y = HEADER_HEIGHT + 80;
    int index = 0;
    
    for (auto& ver : localVersions) {
        VersionItem item;
        item.version = ver;
        item.rect = {100, y, 1080, 60};
        item.selected = (index == 0);
        item.isLocal = true;
        
        m_versionItems.push_back(item);
        
        y += 70;
        index++;
    }
    
    // TODO: Load cloud versions from Google Drive
    // auto cloudFiles = m_drive.listFiles(m_drive.getRootFolderId());
    // for (auto& file : cloudFiles) { ... }
}

void MainUI::renderVersionHistory() {
    // Title
    renderText("버전 관리", 100, HEADER_HEIGHT + 20, m_fontLarge, Color::Accent);
    
    if (m_selectedTitle) {
        renderText(m_selectedTitle->name, 350, HEADER_HEIGHT + 25, m_fontMedium, Color::Text);
    }
    
    int y = HEADER_HEIGHT + 70;
    
    // ========== CURRENT SAVE ========== 
    renderText("▶ 현재 세이브 (Switch)", 100, y, m_fontMedium, Color::Accent);
    y += 35;
    
    // Current save card (always exists if game has save)
    SDL_Rect currentRect = {100, y, 1080, 70};
    SDL_SetRenderDrawColor(m_renderer, Color::Synced.r, Color::Synced.g, Color::Synced.b, 100);
    SDL_RenderFillRect(m_renderer, &currentRect);
    SDL_SetRenderDrawColor(m_renderer, Color::Synced.r, Color::Synced.g, Color::Synced.b, 255);
    SDL_RenderDrawRect(m_renderer, &currentRect);
    
    renderText("🎮", 120, y + 20, m_fontMedium, Color::Text);
    renderText("현재 게임 데이터", 170, y + 20, m_fontMedium, Color::Text);
    
    char sizeStr[32];
    snprintf(sizeStr, sizeof(sizeStr), "%.2f MB", m_selectedTitle ? m_selectedTitle->saveSize / (1024.0 * 1024.0) : 0);
    renderText(sizeStr, 500, y + 20, m_fontMedium, Color::TextDim);
    
    renderText("[백업] [업로드]", 800, y + 20, m_fontSmall, Color::Accent);
    y += 90;
    
    // ========== LOCAL BACKUPS ==========
    renderText("💾 로컬 백업 (SD 카드)", 100, y, m_fontMedium, Color::Text);
    y += 35;
    
    bool hasLocal = false;
    for (size_t i = 0; i < m_versionItems.size(); i++) {
        VersionItem& item = m_versionItems[i];
        if (!item.isLocal) continue;
        hasLocal = true;
        
        item.selected = ((int)i == m_selectedVersionIndex);
        item.rect = {100, y, 1080, 60};
        
        // Card background
        SDL_Color bgColor = item.selected ? Color::CardHover : Color::Card;
        SDL_SetRenderDrawColor(m_renderer, bgColor.r, bgColor.g, bgColor.b, bgColor.a);
        SDL_RenderFillRect(m_renderer, &item.rect);
        
        if (item.selected) {
            SDL_SetRenderDrawColor(m_renderer, Color::Accent.r, Color::Accent.g,
                                  Color::Accent.b, Color::Accent.a);
            SDL_RenderDrawRect(m_renderer, &item.rect);
        }
        
        int x = item.rect.x + 20;
        int itemY = item.rect.y + 18;
        
        renderText("💾", x, itemY, m_fontMedium, Color::Text);
        
        char timeStr[64];
        strftime(timeStr, sizeof(timeStr), "%Y-%m-%d %H:%M", localtime(&item.version.timestamp));
        renderText(timeStr, x + 50, itemY, m_fontMedium, Color::Text);
        
        snprintf(sizeStr, sizeof(sizeStr), "%.2f MB", item.version.size / (1024.0 * 1024.0));
        renderText(sizeStr, x + 300, itemY, m_fontMedium, Color::TextDim);
        
        if (item.version.isCloudSynced) {
            renderText("☁️", x + 450, itemY, m_fontSmall, Color::Synced);
        }
        
        if (item.selected) {
            renderText("[복원]", x + 500, itemY, m_fontSmall, Color::Accent);
        }
        
        y += 70;
    }
    
    if (!hasLocal) {
        renderText("  백업 없음", 120, y, m_fontSmall, Color::TextDim);
        y += 30;
    }
    
    y += 20;
    
    // ========== CLOUD BACKUPS ==========
    renderText("☁️ 클라우드 백업 (Google Drive)", 100, y, m_fontMedium, Color::Text);
    y += 35;
    
    bool hasCloud = false;
    for (size_t i = 0; i < m_versionItems.size(); i++) {
        VersionItem& item = m_versionItems[i];
        if (item.isLocal) continue;
        hasCloud = true;
        
        item.selected = ((int)i == m_selectedVersionIndex);
        item.rect = {100, y, 1080, 60};
        
        SDL_Color bgColor = item.selected ? Color::CardHover : Color::Card;
        SDL_SetRenderDrawColor(m_renderer, bgColor.r, bgColor.g, bgColor.b, bgColor.a);
        SDL_RenderFillRect(m_renderer, &item.rect);
        
        if (item.selected) {
            SDL_SetRenderDrawColor(m_renderer, Color::Accent.r, Color::Accent.g,
                                  Color::Accent.b, Color::Accent.a);
            SDL_RenderDrawRect(m_renderer, &item.rect);
        }
        
        int x = item.rect.x + 20;
        int itemY = item.rect.y + 18;
        
        renderText("☁️", x, itemY, m_fontMedium, Color::Text);
        
        char timeStr[64];
        strftime(timeStr, sizeof(timeStr), "%Y-%m-%d %H:%M", localtime(&item.version.timestamp));
        renderText(timeStr, x + 50, itemY, m_fontMedium, Color::Text);
        
        snprintf(sizeStr, sizeof(sizeStr), "%.2f MB", item.version.size / (1024.0 * 1024.0));
        renderText(sizeStr, x + 300, itemY, m_fontMedium, Color::TextDim);
        
        if (item.selected) {
            renderText("[다운로드]", x + 500, itemY, m_fontSmall, Color::Accent);
        }
        
        y += 70;
    }
    
    if (!hasCloud && m_drive.isAuthenticated()) {
        renderText("  클라우드 백업 없음", 120, y, m_fontSmall, Color::TextDim);
        y += 30;
    } else if (!m_drive.isAuthenticated()) {
        renderText("  로그인 필요", 120, y, m_fontSmall, Color::NotSynced);
        y += 30;
    }
    
    // Buttons
    m_buttons.clear();
    m_buttons.emplace_back(100, 640, 180, 50, "💾 새 백업");
    m_buttons.emplace_back(300, 640, 180, 50, "☁️ 업로드");
    m_buttons.emplace_back(500, 640, 180, 50, "⬅️ 뒤로");
    
    for (const auto& btn : m_buttons) {
        renderButton(btn);
    }
}

void MainUI::restoreLocalVersion(core::BackupVersion* version) {
    if (!version || !m_selectedTitle) return;
    
    LOG_INFO("Restoring local backup: %s", version->name.c_str());
    
    // Restore from local backup to current save
    m_saveManager.restoreSave(m_selectedTitle, version->path);
    
    // Refresh and go back
    m_state = State::GameDetail;
}

void MainUI::downloadCloudVersion(network::CloudFile* file) {
    if (!file || !m_selectedTitle || !m_drive.isAuthenticated()) return;
    
    LOG_INFO("Downloading cloud backup: %s", file->name.c_str());
    
    // Download directly to current save
    std::string tempPath = "/switch/sos/temp/" + file->id + ".zip";
    m_drive.downloadFile(file->id, tempPath);
    
    // TODO: Extract and restore to current save
    
    m_state = State::GameDetail;
}

// ==================== Conflict Resolution ====================

void MainUI::showConflictResolve() {
    if (!m_selectedTitle) return;
    
    m_conflictStatus = m_drive.getSyncStatus(
        m_saveManager.getBackupPath(m_selectedTitle), "");
    
    // TODO: Get actual timestamps
    m_localTime = "2026-03-03 12:00";
    m_cloudTime = "2026-03-02 18:30";
    
    m_state = State::ConflictResolve;
}

void MainUI::renderConflictResolve() {
    // Dark overlay
    SDL_SetRenderDrawBlendMode(m_renderer, SDL_BLENDMODE_BLEND);
    SDL_SetRenderDrawColor(m_renderer, 0, 0, 0, 200);
    SDL_RenderFillRect(m_renderer, nullptr);
    
    // Conflict card
    SDL_Rect cardRect = {190, 140, 900, 440};
    SDL_SetRenderDrawColor(m_renderer, Color::Card.r, Color::Card.g, Color::Card.b, 255);
    SDL_RenderFillRect(m_renderer, &cardRect);
    
    // Warning header
    renderTextCentered("⚠️ 동기화 충돌", 190, 160, 900, m_fontLarge, Color::Warning);
    
    if (m_selectedTitle) {
        renderTextCentered(m_selectedTitle->name, 190, 210, 900, m_fontMedium, Color::Text);
    }
    
    renderTextCentered("로컬과 클라우드 모두 변경되었습니다.", 190, 260, 900, m_fontMedium, Color::TextDim);
    renderTextCentered("어느 버전을 유지하시겠습니까?", 190, 290, 900, m_fontMedium, Color::TextDim);
    
    // Local option card
    SDL_Rect localRect = {240, 340, 380, 100};
    SDL_SetRenderDrawColor(m_renderer, Color::CardHover.r, Color::CardHover.g,
                          Color::CardHover.b, Color::CardHover.a);
    SDL_RenderFillRect(m_renderer, &localRect);
    
    renderTextCentered("💾 로컬 (내 Switch)", 240, 355, 380, m_fontMedium, Color::Accent);
    renderTextCentered("마지막 수정: " + m_localTime, 240, 390, 380, m_fontSmall, Color::TextDim);
    renderTextCentered("이 버전을 클라우드에 업로드", 240, 415, 380, m_fontSmall, Color::TextDim);
    
    // Cloud option card
    SDL_Rect cloudRect = {660, 340, 380, 100};
    SDL_SetRenderDrawColor(m_renderer, Color::CardHover.r, Color::CardHover.g,
                          Color::CardHover.b, Color::CardHover.a);
    SDL_RenderFillRect(m_renderer, &cloudRect);
    
    renderTextCentered("☁️ 클라우드", 660, 355, 380, m_fontMedium, Color::Accent);
    renderTextCentered("마지막 수정: " + m_cloudTime, 660, 390, 380, m_fontSmall, Color::TextDim);
    renderTextCentered("이 버전을 Switch에 다운로드", 660, 415, 380, m_fontSmall, Color::TextDim);
    
    // Buttons
    m_buttons.clear();
    m_buttons.emplace_back(240, 470, 180, 50, "⬆️ 내 세이브 업로드");
    m_buttons.emplace_back(440, 470, 200, 50, "⬇️ 클라우드 다운로드");
    m_buttons.emplace_back(660, 470, 180, 50, "⬅️ 취소");
    
    for (const auto& btn : m_buttons) {
        renderButton(btn);
    }
}

void MainUI::resolveUpload() {
    // Upload local to cloud, overwriting cloud
    syncSelectedToCloud();
    m_state = State::GameDetail;
    
    // Refresh game cards
    updateGameCards();
}

void MainUI::resolveDownload() {
    // Download from cloud, overwriting local
    downloadFromCloud();
    m_state = State::GameDetail;
    
    // Refresh game cards
    updateGameCards();
}

} // namespace ui
